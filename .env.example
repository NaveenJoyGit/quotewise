# QuoteWise — environment variables (copy to .env and fill in)

# --- WhatsApp provider: meta | twilio ---
WA_PROVIDER=meta

# --- WhatsApp Cloud API (Meta) — when WA_PROVIDER=meta ---
# Verify token: a random string you invent; Meta echoes it back during webhook setup.
WA_VERIFY_TOKEN=change-me-to-a-random-string

# App secret: from Meta app dashboard. Used to HMAC-verify incoming webhooks.
# Leave empty in dev to disable signature verification locally (simulator use only).
WA_APP_SECRET=

# Access token for Graph API calls. When empty, the client runs in mock mode
# (logs outbound messages instead of calling Meta).
WA_ACCESS_TOKEN=

# Phone number ID from Meta dashboard (NOT the phone number itself).
WA_PHONE_NUMBER_ID=

# Graph API version.
WA_GRAPH_API_VERSION=v21.0

# --- Twilio WhatsApp — when WA_PROVIDER=twilio ---
# Inbound webhook URL in Twilio Console: https://<host>/webhooks/twilio/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender, e.g. whatsapp:+14155238886 (sandbox) or your approved WA number
TWILIO_WHATSAPP_FROM=
# If behind ngrok, set the exact public URL Twilio calls (for signature validation)
TWILIO_WEBHOOK_PUBLIC_URL=

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0

# Postgres connection string (SQLAlchemy + psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://quotewise:quotewise@localhost:5432/quotewise

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- LLM ---
# mock: uses deterministic canned responses (no network, for dev/tests)
# vertex: uses Gemini Flash via Google Vertex AI (requires GCP_PROJECT_ID + ADC or service account)
LLM_PROVIDER=mock
GCP_PROJECT_ID=
GCP_LOCATION=asia-south1
VERTEX_MODEL_FLASH=gemini-2.5-flash
VERTEX_MODEL_PRO=gemini-2.5-pro
LLM_CALL_TIMEOUT_SECONDS=20

# Path to GCP service account JSON file (inside the container).
# When set, the app uses this file for Vertex AI auth instead of ADC.
# In Docker, the file is mounted to /secrets/serviceaccount.json automatically.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/serviceaccount.json

# --- Session ---
SESSION_TTL_HOURS=72

# --- PDF & Quote delivery ---
# Local directory where generated PDFs are stored.
PDF_STORAGE_DIR=data/pdfs
# Base URL used to construct the public PDF URL sent to WhatsApp.
# In production, set this to your deployed API hostname (e.g. https://api.shopveluna.in).
PDF_BASE_URL=http://localhost:8000
# Number of days a quote remains valid.
QUOTE_VALIDITY_DAYS=30

# --- CORS ---
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3000

# --- Docker Deployment ---
# Path to GCP service account JSON on the HOST machine.
# Docker Compose mounts this file into the container at /secrets/serviceaccount.json.
GCP_SA_FILE_HOST_PATH=./serviceaccount.json
