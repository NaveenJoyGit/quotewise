# QuoteWise — environment variables (copy to .env and fill in)

# --- WhatsApp Cloud API (Meta) ---
# Verify token: a random string you invent; Meta echoes it back during webhook setup.
WA_VERIFY_TOKEN=change-me-to-a-random-string

# App secret: from Meta app dashboard. Used to HMAC-verify incoming webhooks.
# Leave empty in dev to disable signature verification locally (simulator use only).
WA_APP_SECRET=

# Access token for Graph API calls. When empty, the client runs in mock mode
# (logs outbound messages instead of calling Meta).
WA_ACCESS_TOKEN=

# Phone number ID from Meta dashboard (NOT the phone number itself).
WA_PHONE_NUMBER_ID=

# Graph API version.
WA_GRAPH_API_VERSION=v21.0

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0

# Postgres connection string (SQLAlchemy + psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://quotewise:quotewise@localhost:5432/quotewise

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO
